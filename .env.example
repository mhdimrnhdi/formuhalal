# Backend API URL (used by frontend to connect to backend)
BACKEND_URL=http://localhost:8001

# Database location
DB_URL=data/database.sqlite

# LLM model selection
MODEL=g31l

# Frontend URL (used by backend)
FRONTEND_URL=http://localhost:8000

# ETL scheduler (cron syntax, UTC)
ETL_CRON=0 2 * * 0

# Run the ETL pipeline once when the etl container starts
ETL_RUN_ON_START=true

# Optional override for supplier crawl source
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_PRESET=fast
OLLAMA_MODEL=phi3:latest
OLLAMA_TIMEOUT=3600

# Google Gemini (preferred when key is provided)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=120

# OpenAI ChatGPT (fallback when no Gemini key)
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT=120
