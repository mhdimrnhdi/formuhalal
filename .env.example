# Backend API URL (used by frontend to connect to backend)
BACKEND_URL=http://localhost:8001

# Database location
DB_URL=data/database.sqlite

# LLM model selection
MODEL=g31l

# Frontend URL (used by backend)
FRONTEND_URL=http://localhost:8000

# ETL scheduler (cron syntax, UTC)
ETL_CRON=0 2 * * 0

# Run the ETL pipeline once when the etl container starts
ETL_RUN_ON_START=true

# Optional override for supplier crawl source
# SUPPLIER_CRAWL_URL=https://www.example.com/suppliers
