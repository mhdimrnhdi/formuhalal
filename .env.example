BACKEND_URL=

DB_URL=
MODEL=
FRONTEND_URL=
ETL_CRON=
ETL_RUN_ON_START=

# Ollama (backend LLM substitutes)
# Docker backend must use host.docker.internal (not localhost).
# Ollama must listen on 0.0.0.0 — add to /etc/systemd/system/ollama.service.d/override.conf:
#   [Service]
#   Environment="OLLAMA_HOST=0.0.0.0:11434"
OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_PRESET=fast
# OLLAMA_MODEL=phi3:latest
OLLAMA_TIMEOUT=3600